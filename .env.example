# ===========================================
# 🔑 API KEYS - 실제 키로 교체하세요!
# ===========================================
# OpenAI API 키 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here_replace_with_actual_key

# 심심이 API (사용하지 않음 - 주석처리)
#SIMSIMI_API_KEY=your_simsimi_api_key_here

# ===========================================
# 📝 프로젝트 정보
# ===========================================
PROJECT_NAME=teen-empathy-chatbot
VERSION=2.0.0
AUTHOR=youdie006@naver.com
GITHUB_REPO=https://github.com/youdie006/simsimi-ai-agent
DESCRIPTION=13-19세 청소년을 위한 AI 공감 상담사

# ===========================================
# 🗄️ Vector Database 설정
# ===========================================
VECTOR_DB_TYPE=chromadb
CHROMADB_PATH=/app/data/chromadb
COLLECTION_NAME=teen_empathy_chat

# ===========================================
# 🤖 AI 모델 설정
# ===========================================
# 한국어 특화 임베딩 모델
EMBEDDING_MODEL=jhgan/ko-sbert-multitask
EMBEDDING_DIMENSION=768
TOP_K_RESULTS=5

# OpenAI 모델 설정
OPENAI_MODEL=gpt-4
MAX_TOKENS=2000
TEMPERATURE=0.7

# ===========================================
# 🌐 API 서버 설정
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ===========================================
# 📊 AI Hub 데이터 설정
# ===========================================
# AI Hub 데이터 저장 경로
AIHUB_DATA_DIR=/app/data/aihub

# ===========================================
# 🌐 웹 인터페이스 설정
# ===========================================
# 정적 파일 디렉토리
STATIC_DIR=/app/static

# ===========================================
# 🧠 청소년 공감형 챗봇 설정
# ===========================================
# 감정 감지 설정
EMOTION_DETECTION=enabled
EMOTION_CONFIDENCE_THRESHOLD=0.7

# 공감 전략 설정 (격려,동조,위로,조언)
EMPATHY_STRATEGIES=격려,동조,위로,조언
DEFAULT_EMPATHY_STRATEGY=위로

# ReAct 패턴 설정 (단계별 추론)
REACT_PATTERN=enabled
INCLUDE_REASONING_DEFAULT=false

# 청소년 맥락 변환 설정 (직장→학교, 동료→친구)
TEEN_CONTEXT_CONVERSION=enabled
SPEECH_LEVEL_ADJUSTMENT=enabled

# ===========================================
# 🔒 청소년 안전 및 보안 설정
# ===========================================
# 청소년 안전 모드
TEEN_SAFETY_MODE=true
CONTENT_FILTER=enabled
CONVERSATION_MONITORING=enabled
CRISIS_DETECTION=enabled

# 개인정보 보호
ANONYMIZE_CONVERSATIONS=true
STORE_PERSONAL_INFO=false
DATA_RETENTION_DAYS=0

# ===========================================
# 🎯 성능 최적화 설정
# ===========================================
# 벡터 검색 최적화
VECTOR_SEARCH_TIMEOUT=30
BATCH_PROCESSING_SIZE=100

# 응답 시간 최적화
RESPONSE_CACHE=enabled
CACHE_TTL=3600

# 동시 요청 처리
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60

# ===========================================
# 📈 모니터링 및 분석 설정
# ===========================================
# 사용량 통계
COLLECT_USAGE_STATS=true
ANALYTICS_ENABLED=true

# 품질 평가
RESPONSE_QUALITY_TRACKING=enabled
USER_FEEDBACK_COLLECTION=enabled

# 헬스 체크
HEALTH_CHECK_INTERVAL=30
AUTO_RECOVERY=enabled

# ===========================================
# 🎨 UI/UX 설정
# ===========================================
# 웹 인터페이스 테마
UI_THEME=teen_friendly
COLOR_SCHEME=gradient_blue_purple

# 채팅 설정
MAX_MESSAGE_LENGTH=1000
TYPING_INDICATOR=enabled
QUICK_REPLY_BUTTONS=enabled

# 반응형 디자인
MOBILE_OPTIMIZED=true
TABLET_OPTIMIZED=true

# ===========================================
# 🔧 개발 및 테스트 설정
# ===========================================
# 개발 모드
DEVELOPMENT_MODE=true
AUTO_RELOAD=true

# 테스트 설정
CREATE_SAMPLE_DATA=true
TEST_MODE=false
MOCK_API_CALLS=false

# 디버깅
VERBOSE_LOGGING=true
ERROR_REPORTING=enabled

# ===========================================
# 🚀 배포 환경별 설정 예시
# ===========================================
# 개발 환경
# DEBUG=true
# LOG_LEVEL=DEBUG
# CREATE_SAMPLE_DATA=true

# 운영 환경
# DEBUG=false
# LOG_LEVEL=INFO
# CREATE_SAMPLE_DATA=false
# MAX_CONCURRENT_REQUESTS=50
# WORKERS=4

# 테스트 환경
# TEST_MODE=true
# COLLECTION_NAME=test_teen_empathy_chat
# MOCK_API_CALLS=true