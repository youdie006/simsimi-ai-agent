# ===========================================
# 🔑 API KEYS - 실제 키로 교체하세요!
# ===========================================
OPENAI_API_KEY=your_openai_key_here
SIMSIMI_API_KEY=your_simsimi_key_here

# ===========================================
# 📝 프로젝트 정보
# ===========================================
PROJECT_NAME=simsimi-ai-agent
VERSION=1.0.0
AUTHOR=youdie006@naver.com
GITHUB_REPO=https://github.com/youdie006/simsimi-ai-agent

# ===========================================
# 🗄️ Vector Database 설정
# ===========================================
VECTOR_DB_TYPE=chromadb
CHROMADB_PATH=/app/data/chromadb
COLLECTION_NAME=simsimi_conversations

# ===========================================
# 🤖 AI 모델 설정
# ===========================================
EMBEDDING_MODEL=jhgan/ko-sbert-multitask
EMBEDDING_DIMENSION=768
TOP_K_RESULTS=5
OPENAI_MODEL=gpt-4
MAX_TOKENS=2000
TEMPERATURE=0.7

# ===========================================
# 🌐 API 서버 설정
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO