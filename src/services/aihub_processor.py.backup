"""
AI Hub 공감형 대화 데이터 처리기 - 실제 구조 대응 버전
실제 utterances 배열과 info 객체 구조에 맞게 수정
"""

import json
import os
import re
from pathlib import Path
from typing import Dict, List, Optional, Tuple
from dataclasses import dataclass, asdict
from datetime import datetime
import uuid
import time

from loguru import logger
from ..core.vector_store import get_vector_store
from ..models.vector_models import DocumentInput
from ..models.function_models import EmotionType, RelationshipType, EmpathyStrategy


@dataclass
class TeenDialogSession:
    """청소년 대화 세션 데이터 - 실제 구조 대응"""
    session_id: str
    user_utterance: str
    system_response: str
    emotion: str
    relationship: str
    empathy_label: str
    teen_context: Dict[str, str]
    original_conversation_id: str
    utterance_pair_id: int


@dataclass
class AIHubParsingStats:
    """AI Hub 파싱 통계"""
    total_files: int
    successful_files: int
    total_conversations: int
    total_utterance_pairs: int
    emotion_distribution: Dict[str, int]
    relationship_distribution: Dict[str, int]
    empathy_distribution: Dict[str, int]


class FixedTeenEmpathyDataProcessor:
    """실제 AI Hub 구조에 맞는 데이터 처리기"""

    def __init__(self, data_dir: str = "./data"):
        self.data_dir = Path(data_dir)
        self.data_dir.mkdir(parents=True, exist_ok=True)

        # 청소년 맥락 변환 매핑 (기존과 동일)
        self.teen_context_mapping = {
            "relationship": {
                "부모자녀": "부모님",
                "부모자녀/조손": "부모님",
                "부부": "부모님",  # 부부 관계를 부모님으로
                "직장동료": "친구",
                "지인": "동급생",
                "연인": "좋아하는 사람",
                "형제자매": "형제자매",
                "친구": "친구"
            },
            "situation_words": {
                # 직장 → 학교 변환
                "직장": "학교", "회사": "학교", "업무": "공부", "동료": "친구",
                "상사": "선생님", "부장": "담임선생님", "팀장": "반장",
                "회의": "수업", "프로젝트": "과제", "출근": "등교", "퇴근": "하교",
                "야근": "야자", "휴가": "방학", "월급": "용돈", "승진": "성적 향상",
                "면접": "입시", "거래처": "다른 학교", "계약": "시험", "발표": "발표",

                # 가정 환경
                "아기": "동생", "손주": "조카", "며느리": "형수", "사위": "매형",
                "시어머니": "할머니", "시아버지": "할아버지"
            }
        }

        # 감정별 공감 전략
        self.empathy_strategies = {
            "기쁨": ["격려", "동조"],
            "당황": ["위로", "조언"],
            "분노": ["위로", "동조"],
            "불안": ["위로", "격려"],
            "상처": ["위로", "격려"],
            "슬픔": ["위로", "동조"]
        }

    def load_aihub_data(self, file_paths: List[str]) -> List[Dict]:
        """실제 AI Hub JSON 파일들 로드"""
        all_sessions = []
        parsing_stats = AIHubParsingStats(
            total_files=len(file_paths),
            successful_files=0,
            total_conversations=0,
            total_utterance_pairs=0,
            emotion_distribution={},
            relationship_distribution={},
            empathy_distribution={}
        )

        for file_path in file_paths:
            try:
                if not os.path.exists(file_path):
                    continue

                with open(file_path, 'r', encoding='utf-8') as f:
                    data = json.load(f)

                # 실제 구조에 맞게 파싱
                sessions = self._parse_aihub_conversation(data, file_path)
                all_sessions.extend(sessions)

                if sessions:
                    parsing_stats.successful_files += 1
                    parsing_stats.total_conversations += 1
                    parsing_stats.total_utterance_pairs += len(sessions)

                    # 통계 업데이트
                    for session in sessions:
                        # 감정 분포
                        emotion = session.get('emotion', '')
                        parsing_stats.emotion_distribution[emotion] = parsing_stats.emotion_distribution.get(emotion, 0) + 1

                        # 관계 분포
                        relationship = session.get('relationship', '')
                        parsing_stats.relationship_distribution[relationship] = parsing_stats.relationship_distribution.get(relationship, 0) + 1

                        # 공감 전략 분포
                        empathy = session.get('empathy_label', '')
                        parsing_stats.empathy_distribution[empathy] = parsing_stats.empathy_distribution.get(empathy, 0) + 1

            except Exception as e:
                logger.error(f"파일 로드 실패 {file_path}: {e}")
                continue

        logger.info(f"📊 AI Hub 파싱 완료:")
        logger.info(f"  성공한 파일: {parsing_stats.successful_files}/{parsing_stats.total_files}")
        logger.info(f"  총 대화: {parsing_stats.total_conversations}개")
        logger.info(f"  총 발화쌍: {parsing_stats.total_utterance_pairs}개")
        logger.info(f"  감정 분포: {dict(list(parsing_stats.emotion_distribution.items())[:5])}")
        logger.info(f"  관계 분포: {dict(list(parsing_stats.relationship_distribution.items())[:5])}")

        return all_sessions

    def _parse_aihub_conversation(self, data: Dict, file_path: str) -> List[Dict]:
        """실제 AI Hub 대화 구조 파싱"""
        sessions = []

        try:
            # info 정보 추출
            info = data.get('info', {})
            emotion = info.get('speaker_emotion', '불안')
            relationship = info.get('relation', '친구')
            speaker_relation = info.get('speaker_relation', '')
            conversation_id = info.get('id', str(uuid.uuid4()))

            # utterances 배열 파싱
            utterances = data.get('utterances', [])
            if not utterances:
                return sessions

            # speaker-listener 쌍으로 그룹핑
            current_speaker = None
            current_listener = None
            pair_id = 0

            for utterance in utterances:
                role = utterance.get('role', '')
                text = utterance.get('text', '').strip()
                empathy_labels = utterance.get('listener_empathy', [])

                if not text:
                    continue

                if role == 'speaker':
                    # 이전 쌍이 완성되었으면 저장
                    if current_speaker and current_listener:
                        sessions.append(self._create_session_dict(
                            conversation_id, pair_id, current_speaker, current_listener,
                            emotion, relationship, empathy_labels, file_path
                        ))
                        pair_id += 1

                    current_speaker = text
                    current_listener = None

                elif role == 'listener':
                    current_listener = text
                    # speaker-listener 쌍 완성
                    if current_speaker:
                        # 공감 라벨 결정
                        empathy_label = self._determine_empathy_label(empathy_labels, emotion)

                        sessions.append(self._create_session_dict(
                            conversation_id, pair_id, current_speaker, current_listener,
                            emotion, relationship, empathy_label, file_path
                        ))
                        pair_id += 1
                        current_speaker = None
                        current_listener = None

        except Exception as e:
            logger.error(f"대화 파싱 실패 {file_path}: {e}")

        return sessions

    def _create_session_dict(self, conversation_id: str, pair_id: int,
                           speaker_text: str, listener_text: str,
                           emotion: str, relationship: str, empathy_label: str,
                           file_path: str) -> Dict:
        """세션 딕셔너리 생성"""
        session_id = f"{conversation_id}_pair_{pair_id}"

        return {
            'session_id': session_id,
            'user_utterance': speaker_text,
            'system_response': listener_text,
            'emotion': emotion,
            'relationship': relationship,
            'empathy_label': empathy_label,
            'original_conversation_id': conversation_id,
            'utterance_pair_id': pair_id,
            'file_source': os.path.basename(file_path)
        }

    def _determine_empathy_label(self, empathy_labels: List[str], emotion: str) -> str:
        """공감 라벨 결정"""
        if empathy_labels and empathy_labels[0]:
            return empathy_labels[0]

        # 감정 기반 기본 전략
        default_strategies = self.empathy_strategies.get(emotion, ["위로"])
        return default_strategies[0]

    def convert_to_teen_context(self, text: str, relationship: str) -> Tuple[str, Dict[str, str]]:
        """성인 대화를 청소년 맥락으로 변환"""
        converted_text = text
        conversion_log = {}

        # 관계 변환
        if relationship in self.teen_context_mapping["relationship"]:
            teen_relationship = self.teen_context_mapping["relationship"][relationship]
            conversion_log["relationship"] = f"{relationship} → {teen_relationship}"

        # 상황/단어 변환
        for adult_word, teen_word in self.teen_context_mapping["situation_words"].items():
            if adult_word in converted_text:
                converted_text = converted_text.replace(adult_word, teen_word)
                conversion_log[adult_word] = teen_word

        # 존댓말 레벨 조정
        if relationship in ["친구", "동급생", "형제자매"]:
            converted_text = self._adjust_to_casual_speech(converted_text)
            conversion_log["speech_level"] = "반말로 조정"

        return converted_text, conversion_log

    def _adjust_to_casual_speech(self, text: str) -> str:
        """존댓말을 반말로 조정"""
        patterns = [
            (r'습니다\.', '야.'), (r'해요\.', '해.'), (r'이에요\.', '이야.'),
            (r'에요\.', '야.'), (r'죠\.', '지.'), (r'하세요', '해'),
            (r'드려요', '줄게'), (r'입니다', '이야'), (r'까요\?', '까?'),
        ]

        for pattern, replacement in patterns:
            text = re.sub(pattern, replacement, text)

        return text

    def process_dialog_session(self, raw_data: Dict) -> Optional[TeenDialogSession]:
        """단일 대화 세션을 청소년 맥락으로 처리 - 실제 구조 대응"""
        try:
            # 실제 AI Hub 구조에서 필드 추출
            session_id = raw_data.get('session_id', str(uuid.uuid4()))
            user_utterance = raw_data.get('user_utterance', '')
            system_response = raw_data.get('system_response', '')
            emotion = raw_data.get('emotion', '불안')
            relationship = raw_data.get('relationship', '친구')
            empathy_label = raw_data.get('empathy_label', '위로')

            if not user_utterance or not system_response:
                return None

            # 청소년 맥락 변환
            teen_user_utterance, user_conversion = self.convert_to_teen_context(
                user_utterance, relationship
            )
            teen_system_response, system_conversion = self.convert_to_teen_context(
                system_response, relationship
            )

            # 관계도 청소년 맥락으로 변환
            teen_relationship = self.teen_context_mapping["relationship"].get(
                relationship, relationship
            )

            return TeenDialogSession(
                session_id=session_id,
                user_utterance=teen_user_utterance,
                system_response=teen_system_response,
                emotion=emotion,
                relationship=teen_relationship,
                empathy_label=empathy_label,
                teen_context={
                    "original_relationship": relationship,
                    "user_conversions": user_conversion,
                    "system_conversions": system_conversion,
                    "conversion_applied": bool(user_conversion or system_conversion)
                },
                original_conversation_id=raw_data.get('original_conversation_id', ''),
                utterance_pair_id=raw_data.get('utterance_pair_id', 0)
            )

        except Exception as e:
            logger.error(f"세션 처리 실패: {e}")
            return None

    async def process_and_index_data(self, file_paths: List[str]) -> 'ProcessingStats':
        """전체 데이터 처리 및 벡터 인덱싱 - 실제 구조 대응"""
        start_time = datetime.now()

        # 1. AI Hub 데이터 로드 (새로운 파싱 로직)
        raw_data_list = self.load_aihub_data(file_paths)
        if not raw_data_list:
            logger.warning("로드된 데이터가 없습니다")
            from ..services.aihub_processor import ProcessingStats
            return ProcessingStats(0, 0, {}, {}, {}, str(datetime.now() - start_time))

        # 2. 청소년 맥락으로 변환
        processed_sessions = []
        for raw_data in raw_data_list:
            session = self.process_dialog_session(raw_data)
            if session:
                processed_sessions.append(session)

        if not processed_sessions:
            logger.warning("처리된 세션이 없습니다")
            from ..services.aihub_processor import ProcessingStats
            return ProcessingStats(0, 0, {}, {}, {}, str(datetime.now() - start_time))

        logger.info(f"📊 데이터 처리 완료: {len(processed_sessions)}개 세션")

        # 3. 통계 계산
        stats = self._calculate_stats(processed_sessions)

        # 4. 벡터 스토어에 인덱싱
        await self._index_to_vector_store(processed_sessions)

        # 5. 처리 시간 기록
        processing_time = str(datetime.now() - start_time)
        stats.processing_time = processing_time

        logger.info(f"✅ 전체 처리 완료: {stats.total_sessions}개 세션 ({processing_time})")
        return stats

    def _calculate_stats(self, sessions: List[TeenDialogSession]) -> 'ProcessingStats':
        """처리 통계 계산"""
        from ..services.aihub_processor import ProcessingStats

        emotion_dist = {}
        relationship_dist = {}
        empathy_dist = {}
        teen_converted = 0

        for session in sessions:
            emotion_dist[session.emotion] = emotion_dist.get(session.emotion, 0) + 1
            relationship_dist[session.relationship] = relationship_dist.get(session.relationship, 0) + 1
            empathy_dist[session.empathy_label] = empathy_dist.get(session.empathy_label, 0) + 1

            if session.teen_context.get("conversion_applied"):
                teen_converted += 1

        return ProcessingStats(
            total_sessions=len(sessions),
            teen_converted=teen_converted,
            emotion_distribution=emotion_dist,
            relationship_distribution=relationship_dist,
            empathy_distribution=empathy_dist,
            processing_time=""
        )

    async def _index_to_vector_store(self, sessions: List[TeenDialogSession]):
        """ChromaDB 벡터 스토어에 인덱싱"""
        try:
            vector_store = await get_vector_store()

            documents = []
            for session in sessions:
                # 검색용 텍스트 구성
                search_content = f"[{session.emotion}] [{session.relationship}] {session.user_utterance}"

                # 메타데이터에 모든 정보 포함
                metadata = {
                    "session_id": session.session_id,
                    "user_utterance": session.user_utterance,
                    "system_response": session.system_response,
                    "emotion": session.emotion,
                    "relationship": session.relationship,
                    "empathy_label": session.empathy_label,
                    "teen_context": json.dumps(session.teen_context),
                    "data_source": "aihub",
                    "processed_for": "teen_empathy",
                    "indexed_at": datetime.now().isoformat(),
                    "original_conversation_id": session.original_conversation_id,
                    "utterance_pair_id": session.utterance_pair_id
                }

                documents.append(DocumentInput(
                    content=search_content,
                    metadata=metadata,
                    document_id=session.session_id
                ))

            # 벡터 스토어에 추가
            logger.info(f"🔄 벡터 인덱싱 시작: {len(documents)}개 문서")
            await vector_store.add_documents(documents)
            logger.info("✅ 벡터 인덱싱 완료")

        except Exception as e:
            logger.error(f"❌ 벡터 인덱싱 실패: {e}")
            raise

        async def search_similar_contexts(self, query: str, emotion: str = None,
                                    relationship: str = None, top_k: int = 5) -> List[Dict]:
        """유사한 대화 맥락 검색"""
        try:
            vector_store = await get_vector_store()

            # 벡터 스토어 상태 확인
            stats = await vector_store.get_collection_stats()
            if stats.total_documents == 0:
                logger.warning("⚠️ 벡터 스토어가 비어있음")
                return []

            # 검색 쿼리 구성 (올바른 순서: [감정] [관계] 내용)
            search_query = query
            if emotion and relationship:
                search_query = f"[{emotion}] [{relationship}] {search_query}"
            elif emotion:
                search_query = f"[{emotion}] {search_query}"
            elif relationship:
                search_query = f"[{relationship}] {search_query}"

            logger.info(f"🔍 검색 쿼리: '{search_query}'")

            # 벡터 검색 실행
            results = await vector_store.search(
                query=search_query,
                top_k=top_k * 2,
                filter_metadata={"data_source": "aihub_unified"}
            )

            # 결과 포맷팅 (임계값 0.05)
            formatted_results = []
            for result in results:
                if result.score < 0.05:  # 매우 낮은 임계값
                    continue

                formatted_results.append({
                    "user_utterance": result.metadata.get("user_utterance", ""),
                    "system_response": result.metadata.get("system_response", ""),
                    "emotion": result.metadata.get("emotion", ""),
                    "relationship": result.metadata.get("relationship", ""),
                    "empathy_label": result.metadata.get("empathy_label", ""),
                    "similarity_score": result.score,
                    "teen_context": {}
                })

            # 유사도 순 정렬 후 상위 결과만 반환
            formatted_results.sort(key=lambda x: x["similarity_score"], reverse=True)
            logger.info(f"✅ 검색 완료: {len(formatted_results)}개 결과")
            
            return formatted_results[:top_k]

        except Exception as e:
            logger.error(f"❌ 유사 맥락 검색 실패: {e}")
            return []

    def get_empathy_strategy(self, emotion: str) -> List[str]:
        """감정에 따른 공감 전략 추천"""
        return self.empathy_strategies.get(emotion, ["위로", "격려"])


# 전역 인스턴스
_fixed_processor_instance = None

async def get_fixed_teen_empathy_processor() -> FixedTeenEmpathyDataProcessor:
    """수정된 청소년 공감 데이터 처리기 싱글톤 인스턴스"""
    global _fixed_processor_instance

    if _fixed_processor_instance is None:
        data_dir = os.getenv("AIHUB_DATA_DIR", "./data/aihub")
        _fixed_processor_instance = FixedTeenEmpathyDataProcessor(data_dir)

    return _fixed_processor_instance
# 호환성을 위한 함수 추가
async def get_teen_empathy_processor():
    """호환성을 위한 함수 - 기존 함수명 사용"""
    global _processor_instance
    
    if _processor_instance is None:
        data_dir = os.getenv("AIHUB_DATA_DIR", "./data/aihub")
        _processor_instance = FixedTeenEmpathyDataProcessor(data_dir)
    
    return _processor_instance

# 전역 인스턴스 변수 정의 (누락된 것 추가)
_processor_instance = None

# 전역 인스턴스 변수 정의 (누락된 것 추가)
_processor_instance = None
