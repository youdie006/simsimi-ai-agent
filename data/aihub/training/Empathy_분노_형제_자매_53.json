    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오빠 나 오늘 사무실에서 너무 불합리한 일을 당했어.",
            "utterance_id": "BE22002565.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응? 무슨 일 때문에 이렇게 화가 났어?",
            "utterance_id": "BE22002565.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "글쎄 오늘부터 20분 일찍 출근해서 업무 시작 전에 사무실 청소를 하라잖아.",
            "utterance_id": "BE22002565.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사장님이 너에게만 그러라고 하셔?",
            "utterance_id": "BE22002565.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응! 내가 입사 막내라고 청소는 꼭 막내 혼자 해야 한대.",
            "utterance_id": "BE22002565.5"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그런 게 어딨어! 막내라 무조건 해야 한다는 것은 정말 합당하지 못한 것 같은데.",
            "utterance_id": "BE22002565.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞지? 그런데 솔직히 입사한 지 얼마 되지 않아서 싫다는 말을 하지 못했어.",
            "utterance_id": "BE22002565.7"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "저런. 왠지 너의 상황이 이해는 간다. 나라도 조금 어려웠을 것 같아.",
            "utterance_id": "BE22002565.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그런데 이게 너무 억울해서 너무 하기 싫은데 어떻게 하면 좋을까?",
            "utterance_id": "BE22002565.9"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내 동생 많이 억울했구나. 종일 고민하느라 마음이 많이 힘들었겠구나.",
            "utterance_id": "BE22002565.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아. 혼자서 종일 끙끙거리고 있었어.",
            "utterance_id": "BE22002565.11"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사수에게 조심스럽게 말해보는 것은 어떻겠니?",
            "utterance_id": "BE22002565.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내 마음을 잘 이해해줄까?",
            "utterance_id": "BE22002565.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "예의를 갖춰서 네 불합리함을 이야기한다면 네 억울함을 이해해주지 않을까?",
            "utterance_id": "BE22002565.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "정말 그럴까? 그렇다면 한번 시도해 볼래.",
            "utterance_id": "BE22002565.15"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너는 언제든 똑 부러지는 사람이니까 이번 일도 대화로 잘 극복해낼 수 있을 거야.",
            "utterance_id": "BE22002565.16"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "그렇게 생각해주니까 너무 든든해. 고마워.",
            "utterance_id": "BE22002565.17"
        }
    ]
}