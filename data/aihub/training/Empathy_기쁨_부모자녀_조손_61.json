    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘 편의점 손님이 저한테 군인이냐고 물었어요.",
            "utterance_id": "BE22001672.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 딸이 군인처럼 보이지는 않는데 왜 그랬을까?",
            "utterance_id": "BE22001672.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "티셔츠가 비슷해서 오해한 거래요.",
            "utterance_id": "BE22001672.3"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그랬구나. 그 말 듣고 황당했겠는데?",
            "utterance_id": "BE22001672.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "처음에는 그랬는데 나중에는 괜히 으쓱해서 좋았어요.",
            "utterance_id": "BE22001672.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "왜 우리 딸이 우쭐한 기분이 들었을까?",
            "utterance_id": "BE22001672.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사실 저 어렸을 때 군인이 되고 싶었거든요.",
            "utterance_id": "BE22001672.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아, 너 고등학교 때까지 그런 말 자주 했어.",
            "utterance_id": "BE22001672.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그때 텔레비전에서 군대 체험 프로그램이 인기 있었잖아요.",
            "utterance_id": "BE22001672.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "여자 연예인들이 군대 가는 거 나오고 그랬지.",
            "utterance_id": "BE22001672.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그거 보면서 입대하고 싶었는데 키 작고 비리비리해서 금방 포기했어요.",
            "utterance_id": "BE22001672.11"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마가 말은 안 했지만 너 고집 부리면 어쩌나 그랬어. 약하고 잔병치레가 잦은 애라서.",
            "utterance_id": "BE22001672.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "한때 진지한 꿈이었거든요. 오늘 그때 생각도 나고 잠시나마 군인이 된 기분이 들었어요.",
            "utterance_id": "BE22001672.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그래서 그 말에 의기양양했구나. 오해였지만 덕분에 소원 풀이는 한 셈이네. 축하해!",
            "utterance_id": "BE22001672.14"
        }
    ]
}