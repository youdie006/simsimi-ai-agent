    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "금요일 밤 드라마 보는 재미가 꿀이야.",
            "utterance_id": "BE22001624.1"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내일이 휴일이니 몸과 마음이 여유가 있어 드라마가 더 재미있겠어.",
            "utterance_id": "BE22001624.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "휴일 전날 밤, 몸과 마음이 가장 편안한 거 같아. 참 행복해.",
            "utterance_id": "BE22001624.3"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아. 토요일 일요일 쉰다는 게 행복하게 느껴지지. 그 행복한 기분 나도 잘 알아.",
            "utterance_id": "BE22001624.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "예전에는 금요일 밤에 친구들 만나 밤늦게까지 노는 게 참 재미있었어.",
            "utterance_id": "BE22001624.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래 맞아. 젊었을 때는 밤늦도록 시내를 다니고 술 마시고 그랬지.",
            "utterance_id": "BE22001624.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지금은 집에 일찍 와 드라마 보는 게 더 좋아.",
            "utterance_id": "BE22001624.7"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 그렇더라. 맥주 한 캔 곁들이면 금상첨화지.",
            "utterance_id": "BE22001624.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "세상 부러울 게 없어.",
            "utterance_id": "BE22001624.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "행복이 뭐 별거야? 이런 게 행복이지.",
            "utterance_id": "BE22001624.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맥주가 들어가면 주인공한테 감정이입이 더 잘되는 거 같아.",
            "utterance_id": "BE22001624.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "일주일 쌓인 피로가 풀리는 거 같지?",
            "utterance_id": "BE22001624.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "매일 반복되는 일상에서 벗어나는 느낌을 주지.",
            "utterance_id": "BE22001624.13"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네가 회사 생활을 열심히 한다는 증거 아니겠어?",
            "utterance_id": "BE22001624.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 회사 일을 열심히 하긴 하지.",
            "utterance_id": "BE22001624.15"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아. 열심히 한 만큼 달콤한 휴일을 즐기라고.",
            "utterance_id": "BE22001624.16"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그래야지. 너도 달달한 금요일 밤 되기를.",
            "utterance_id": "BE22001624.17"
        }
    ]
}