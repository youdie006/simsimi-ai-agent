    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "야, 큰일 났어. 공원 화장실에 휴지가 없어.",
            "utterance_id": "BE22001091.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "뭐? 옆 칸에도 없어? 아니면 지금 네가 있는 칸에 없다는 건가?",
            "utterance_id": "BE22001091.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "볼일을 다 봤는데, 없어. 너무 불안해서 미칠 지경이야.",
            "utterance_id": "BE22001091.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "화장실에 아무도 없어? 다른 사람한테 부탁해서 휴지 좀 달라고 할 수도 없는 거지?",
            "utterance_id": "BE22001091.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아무도 없는 것 같은데. 이거 어떡하지?",
            "utterance_id": "BE22001091.5"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게, 너무 당황스럽겠어. 나라도 그런 상황에서는 식은땀이 흐를 것 같아.",
            "utterance_id": "BE22001091.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나 저번에도 사람 올 때까지 한참을 기다렸잖아.",
            "utterance_id": "BE22001091.7"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아 진짜? 부탁할 때도 엄청 부끄러웠겠는걸.",
            "utterance_id": "BE22001091.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러니까. 얼굴이 얼마나 뜨겁던지. 저는 또 기다리게 생겼어.",
            "utterance_id": "BE22001091.9"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "걱정 마. 금방 올 거예. 거기 공원에 오가는 사람들 많으니까.",
            "utterance_id": "BE22001091.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그런데 옆 칸에는 휴지가 있겠지?",
            "utterance_id": "BE22001091.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그럼. 설마 모든 칸의 휴지가 다 떨어지기라도 했겠어?",
            "utterance_id": "BE22001091.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "빨리 왔으면 좋겠어. 화장실 엄청 더워.",
            "utterance_id": "BE22001091.13"
        },
        {
            "listener_empathy": [
                "격려",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "공원이라 사람이 많은 곳이니 곧 사람이 들어올 테니 조금만 기다려봐. 얼마나 불안할까.",
            "utterance_id": "BE22001091.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "오! 드디어 사람 들어왔다! 내가 다시 연락할게.",
            "utterance_id": "BE22001091.15"
        }
    ]
}