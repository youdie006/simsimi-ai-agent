    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "여보. 혹시 나 요즘 입 냄새나?",
            "utterance_id": "BE22001086.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "안 그래도 어디 아픈가 물어보려고 했어.",
            "utterance_id": "BE22001086.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "하 역시 계속 신경 쓰였는데 좀 그랬구나.",
            "utterance_id": "BE22001086.3"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "자기 혼자 고민하느니 힘들었지. 어떻게 말을 꺼내야 할지 망설이던 것뿐이야. 아픈 건 아닌지 걱정도 되고.",
            "utterance_id": "BE22001086.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "좀 부끄럽기도 하고 해서 말 못 했어.",
            "utterance_id": "BE22001086.5"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우린 부부인데 뭐가 부끄러워. 난 그냥 걱정될 뿐이야.",
            "utterance_id": "BE22001086.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "그렇게 말해주니 너무 고맙다.",
            "utterance_id": "BE22001086.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "다른 걸 떠나서 아픈 것일 수도 있으니까 병원부터 가볼까?",
            "utterance_id": "BE22001086.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 일단 치과부터 가봐야겠다.",
            "utterance_id": "BE22001086.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래. 자기 잇몸에 원래 좀 약하잖아.",
            "utterance_id": "BE22001086.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "흠 병원도 가고 치약도 바꿔 볼까?",
            "utterance_id": "BE22001086.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래. 내가 입 냄새에 좋은 치약 찾아볼게.",
            "utterance_id": "BE22001086.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그동안 잇몸도 안 좋은데 치약을 너무 아무거나 썼나 봐.",
            "utterance_id": "BE22001086.13"
        },
        {
            "listener_empathy": [
                "조언",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 좀더 신경 썼어야 했는데 미안해. 그래도 관리하면 금방 좋아질 거니까, 너무 걱정 마.",
            "utterance_id": "BE22001086.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아니야. 이번 기회에 성분도 잘 보고 신중하게 골라보자.",
            "utterance_id": "BE22001086.15"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래. 병원 가서 추천받아 보는 것도 좋을 것 같아.",
            "utterance_id": "BE22001086.16"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "오 그거 좋은 생각이다. 내가 내일 가서 물어보고 올게.",
            "utterance_id": "BE22001086.17"
        }
    ]
}