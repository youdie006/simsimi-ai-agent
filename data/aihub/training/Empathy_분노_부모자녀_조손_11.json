    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마, 이것 좀 봐줘.",
            "utterance_id": "BE22000382.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지금 청소하던 중인데, 왜?",
            "utterance_id": "BE22000382.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이것부터 빨리빨리 봐줘. 심각하단 말이야.",
            "utterance_id": "BE22000382.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "얘가 무슨 일인데, 그러니?",
            "utterance_id": "BE22000382.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "방금 사진 보냈어. 잘 보여?",
            "utterance_id": "BE22000382.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "구두 뒷굽이 아주 작살이 났네. 설마 너 구두로 누구 때린 건 아니지?",
            "utterance_id": "BE22000382.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아니야, 하수도 구멍에 굽이 빠져서 빼느라 엄청 고생했어.",
            "utterance_id": "BE22000382.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래서 넘어졌어? 어디 다치거나 깨지진 않고?",
            "utterance_id": "BE22000382.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응, 구멍에 끼어서 벗겨지기만 하고 다치진 않았어. 구두가 문제야.",
            "utterance_id": "BE22000382.9"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래도 크게 다치지 않은 것만 해도 엄마는 다행이야.",
            "utterance_id": "BE22000382.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지난달에 큰맘 먹고 산 건데. 몇 번 신지도 못했단 말이야.",
            "utterance_id": "BE22000382.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너 어릴 때 하도 넘어져서 무릎이 성한 날 없었던 거 기억 안 나? 흉터 남을까 봐 얼마나 걱정이 많았는데!",
            "utterance_id": "BE22000382.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "약 발라주면서 엄마 눈에 눈물 고였던 거 기억나.",
            "utterance_id": "BE22000382.13"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마가 새 거 사줄 테니까, 구두는 신경 쓰지 말고. 대신 이번에는 조금 낮은 굽으로 사자.",
            "utterance_id": "BE22000382.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "정말? 역시 우리 엄마가 최고야.",
            "utterance_id": "BE22000382.15"
        }
    ]
}