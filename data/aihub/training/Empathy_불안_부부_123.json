    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 아들 시험을 잘 보고 있나 궁금하다.",
            "utterance_id": "BE22003499.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어제 새벽까지 공부하는 것 같던데.",
            "utterance_id": "BE22003499.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "2시 넘어서도 공부하고 있길래 내가 자라고 했어.",
            "utterance_id": "BE22003499.3"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그때까지 당신도 못 잔 거네? 아이 시험 때문에 함께 고생이다.",
            "utterance_id": "BE22003499.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 무슨 고생이야. 아직 어린데 새벽까지 공부 때문에 잠을 못 이루다니 아이 건강이 걱정이지.",
            "utterance_id": "BE22003499.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당신이 아이 건강을 위해 얼마나 많이 노력하고 있는지 모르는 사람이 없지. 덕분에 우리 아이 체력은 확실히 좋잖아.",
            "utterance_id": "BE22003499.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아무리 체력이 좋아도 아직은 성장기예요. 공부도 좋지만 새벽까지 잠을 안 자는 건 난 반대야.",
            "utterance_id": "BE22003499.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 아들은 열성적인 당신을 닮아서 자기 할 일을 뚝심 있게 해내잖아. 아이 건강을 염려하는 당신 마음에 하늘도 감동할 정도인데 아들이라고 모르겠어? 잘 조절할 거야.",
            "utterance_id": "BE22003499.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아빠와 아들이 어쩜 이렇게 하는 말이 비슷한지 참 피는 못 속이네.",
            "utterance_id": "BE22003499.9"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래? 우리 아들이 내 판박이라니 완전 감동인데.",
            "utterance_id": "BE22003499.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아이가 시키지 않아도 열심히 공부하는 것도 사실 당신 닮은 거 같아.",
            "utterance_id": "BE22003499.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그거 다 당신이 사랑으로 정성으로 아이를 잘 키워서 그래.",
            "utterance_id": "BE22003499.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "알았어. 저녁에 아들이 좋아하는 치킨 먹을 거야. 일찍 와.",
            "utterance_id": "BE22003499.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그럴게. 아이 걱정은 그만하고 당신 낮잠 좀 자.",
            "utterance_id": "BE22003499.14"
        }
    ]
}