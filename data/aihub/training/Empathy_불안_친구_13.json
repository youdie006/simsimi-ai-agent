    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "소변이 마려운데 화장실이 안 보여!",
            "utterance_id": "BE22001334.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너 어딘데? 근처에 있는 건물에 들어가 봐.",
            "utterance_id": "BE22001334.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "건물들 몇 개 있는데 다 잠겨 있어. 나 너무 급한데 큰일이네.",
            "utterance_id": "BE22001334.3"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "소변 참는 거 정말 힘든데. 나도 전에 고속버스 안에서 소변이 급해서 무척 애먹었었잖아.",
            "utterance_id": "BE22001334.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "넌 그때 어떻게 했어?",
            "utterance_id": "BE22001334.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "참는 데 한계가 왔을 때 버스가 휴게소에 들르더라고.",
            "utterance_id": "BE22001334.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "근처에 공중화장실이라도 있으면 좋겠는데, 없네.",
            "utterance_id": "BE22001334.7"
        },
        {
            "listener_empathy": [
                "격려",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "가까운 편의점이라도 들어가면 있지 않을까? 어떤 상황인지 알아서 너무 걱정된다.",
            "utterance_id": "BE22001334.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "편의점은 보이지 않네... 그래도 너랑 대화하니까 조금은 낫다.",
            "utterance_id": "BE22001334.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇다면 다행이야. 참으면 좋지 않다고 하는데 빨리 해결할 수 있으면 좋겠어.",
            "utterance_id": "BE22001334.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "건물 뒤에 공원이 있어서 그쪽으로 가려고 하는 중이야.",
            "utterance_id": "BE22001334.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "공원이라면 공중화장실이 있을 수 있겠다.",
            "utterance_id": "BE22001334.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응, 그래서 지금 가는 중이야. 꼭 있었으면 좋겠어.",
            "utterance_id": "BE22001334.13"
        },
        {
            "listener_empathy": [
                "조언",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇게 되면 좋겠다. 어서 열심히 걸어가렴.",
            "utterance_id": "BE22001334.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "어? 찾았어! 네 덕분이야, 친구.",
            "utterance_id": "BE22001334.15"
        }
    ]
}