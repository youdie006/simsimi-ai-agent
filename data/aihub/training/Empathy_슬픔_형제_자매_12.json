    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "언니, 나 이번 면접도 별로 희망이 없는 것 같아.",
            "utterance_id": "BE22000628.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "가기 전까지는 가능성이 많다고 그러더니 갑자기 왜 그래?",
            "utterance_id": "BE22000628.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "면접관이 갑자기 부모님에 대해서 어떻게 생각하는지 물어보잖아.",
            "utterance_id": "BE22000628.3"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아, 네가 많이 당황했겠구나.",
            "utterance_id": "BE22000628.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "솔직하게 부모님이 별거 중이라고 차마 말을 할 수가 없었어.",
            "utterance_id": "BE22000628.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나라도 그런 사정을 있는 그대로 말할 수는 없었을 거야.",
            "utterance_id": "BE22000628.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "화목하고 자애로운 부모님 밑에서 자랐다고 답변을 하는데 얼굴도 벌겋게 되고 말도 더듬거렸어.",
            "utterance_id": "BE22000628.7"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네가 원래 거짓말을 못하는 성격이라 쉽지 않았을 거야.",
            "utterance_id": "BE22000628.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아마 면접관들도 거짓말이라는 걸 눈치챘겠지. 내가 얼마나 한심해 보였을까.",
            "utterance_id": "BE22000628.9"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇게 생각하진 않을 거야. 어떤 사람이든 사연은 한 가지씩 있게 마련인걸.",
            "utterance_id": "BE22000628.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아무튼 그런 지원자를 합격시킬 거라고 생각하진 않아.",
            "utterance_id": "BE22000628.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "만약 그런 이유로 네가 불합격이라면 그런 회사는 안 가도 돼. 그게 너의 결격사유는 아니잖아.",
            "utterance_id": "BE22000628.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇지? 내가 뭘 잘못한 건 아닌 거 맞지?",
            "utterance_id": "BE22000628.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당연하지. 너나 나나 부모님 문제로 자신감을 잃을 필요는 없어.",
            "utterance_id": "BE22000628.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "나도 언니처럼 용기를 내서 더 당당해질래.",
            "utterance_id": "BE22000628.15"
        }
    ]
}