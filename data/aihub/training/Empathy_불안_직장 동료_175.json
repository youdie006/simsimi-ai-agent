    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "퇴사를 해서 수입이 없는데도 소비 습관이 고쳐지질 않네.",
            "utterance_id": "BE22003034.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "소비 습관을 바꾸는 건 생각보다 어려운 일이야. 무슨 일 있어?",
            "utterance_id": "BE22003034.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "돈이 수중에 없어서 충동적으로 카드론을 받았어.",
            "utterance_id": "BE22003034.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "카드론이라니. 어느 회사에 있는 상품에 가입한 건데?",
            "utterance_id": "BE22003034.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나에게 허가를 해주는 곳에서 카드론을 받았지 뭐야. 근데 충동적으로 카드론을 받고 나니 너무 조급하고 걱정스러워.",
            "utterance_id": "BE22003034.5"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "한 번도 카드론 같은 것을 받지 않던 네가 난생처음 그런 일을 겪었구나. 내가 너였어도 걱정이 이만저만이 아닐 것 같아.",
            "utterance_id": "BE22003034.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "매번 배달음식을 먹다 보니 배달음식에 쓰는 돈이 엄청나네.",
            "utterance_id": "BE22003034.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "배달을 줄이기가 쉽지 않지. 그럼 너 요즘 수입은 아예 없는 거니?",
            "utterance_id": "BE22003034.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "집 앞 편의점에서 가끔 아르바이트를 하고 있어. 그래도 내가 받은 카드론의 금액을 채우기에는 아직 모자라서 많이 조급해. 내가 갚을 수 있을까 걱정돼.",
            "utterance_id": "BE22003034.9"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나 같아도 덜컥 카드론을 받아서 마음이 어지럽고 괴로울 것 같아. 게다가 아르바이트라면 네가 벌던 월급에 못 미칠 텐데. 너 정말 걱정되겠다.",
            "utterance_id": "BE22003034.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 왜 그랬는지 아직도 후회돼.",
            "utterance_id": "BE22003034.11"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지금이라도 가계부를 작성해 보는 건 어때?",
            "utterance_id": "BE22003034.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "안 그래도 내가 그 생각을 했어. 가계부라도 써야 할 것 같아.",
            "utterance_id": "BE22003034.13"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나랑 같이 돈을 아끼기 위한 노력을 해보자.",
            "utterance_id": "BE22003034.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "너에게 솔직히 말하니 속이 트이는 것 같아.",
            "utterance_id": "BE22003034.15"
        }
    ]
}