    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생이 장염에 걸릴 것 같아.",
            "utterance_id": "BE22003165.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그게 무슨 말이야? 구체적으로 말해줄래?",
            "utterance_id": "BE22003165.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 먹던 우유가 유통기한이 지나 상했거든. 버리려던 걸 깜빡했는데 그걸 동생이 마셨어.",
            "utterance_id": "BE22003165.3"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생이 상한 우유를 마셔서 너가 정말 걱정스럽겠다. 나 같아도 놀랐을 것 같아. 동생의 상태는 어때?",
            "utterance_id": "BE22003165.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생은 지금 배가 슬슬 아프다고 하고 있어.",
            "utterance_id": "BE22003165.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생도 마실 때 이상함을 느끼지 못한 걸까?",
            "utterance_id": "BE22003165.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 물어보니 냄새가 이상했는데 별 탈 없을 거라고 생각했대.",
            "utterance_id": "BE22003165.7"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내 생각엔 너의 잘못도 동생 잘못도 아닌 것 같아. 운이 없었어.",
            "utterance_id": "BE22003165.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생이 너무 아파서 응급실에 실려 가게 되면 어쩌지?",
            "utterance_id": "BE22003165.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "상한 우유를 마셨다고 해도 약으로 처치가 되는 경우 많아. 최악의 상황은 면할 수 있을 거야. 너의 동생은 워낙 튼튼하니 이겨낼 수 있을거야.",
            "utterance_id": "BE22003165.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇게 말해주니 걱정스러움이 좀 줄어들었어.",
            "utterance_id": "BE22003165.11"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생의 상태를 꾸준히 살펴봐.",
            "utterance_id": "BE22003165.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지금 죽을 쑤는 중이야. 동생에게 주려고.",
            "utterance_id": "BE22003165.13"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "동생에게 주려고 요리를 하다니 너 정말 좋은 누나구나. 분명 고마워할 거야.",
            "utterance_id": "BE22003165.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "그렇게 말해주니 고마워. 덕분에 우리 동생이 금방 나을 것 같아.",
            "utterance_id": "BE22003165.15"
        }
    ]
}