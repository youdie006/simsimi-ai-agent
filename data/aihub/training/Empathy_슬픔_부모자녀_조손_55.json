    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마. 집 도착했어요?",
            "utterance_id": "BE22002844.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 집 방금 도착했어. 우리 딸, 점심은 먹었어?",
            "utterance_id": "BE22002844.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네. 방금 간단히 먹었는데... 갑자기 눈물이 나서...",
            "utterance_id": "BE22002844.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 딸 왜 울어? 그 사이에 무슨 일 있었어?",
            "utterance_id": "BE22002844.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이유는 모르겠는데 그냥 눈물이 나와요. 갑자기 너무 외롭고 엄마도 보고 싶어서 그러는가 봐요.",
            "utterance_id": "BE22002844.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 딸 눈에서 눈물 나온다고 하니까 엄마 마음도 너무 아프네. 엄마도 처음 독립했을 때 이유 모르게 눈물이 안 멈췄던 것 같아. 우리 딸 괜찮아?",
            "utterance_id": "BE22002844.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "첫날이라 그런 것 같아요. 지내다 보면 괜찮아지겠죠?",
            "utterance_id": "BE22002844.7"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "물론이지. 우리 딸 원래 씩씩하고 밝으니까 독립해서도 잘 지낼 수 있을 거야.",
            "utterance_id": "BE22002844.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "엄마 말 들으니까 조금 힘이 나는 것 같아요.",
            "utterance_id": "BE22002844.9"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 기운 내고 밥도 잘 챙겨 먹어. 또 언제든지 집에 오고 싶으면 바로 집으로 달려와. 알았지?",
            "utterance_id": "BE22002844.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네. 엄마. 항상 사랑해요.",
            "utterance_id": "BE22002844.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 나도 우리 딸 사랑해. 엄마도 딸 자취하는 곳에 종종 찾아갈 테니까 너무 외로워하지 말고 잘 지내고 있어.",
            "utterance_id": "BE22002844.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네. 엄마. 또 연락할게요.",
            "utterance_id": "BE22002844.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "응. 저녁에 또 전화하자.",
            "utterance_id": "BE22002844.14"
        }
    ]
}