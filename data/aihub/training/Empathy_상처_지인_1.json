    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "저 어떡하지요? 어제 갑자기 해고 통보받았어요.",
            "utterance_id": "BE22000034.1"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아니 어쩌다가요. 이런 난감한 경우가 있나.",
            "utterance_id": "BE22000034.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게요. 갑자기 통보받고 나니 머리가 하얘집니다.",
            "utterance_id": "BE22000034.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "저라도 그렇겠어요. 이유는 말을 해 주던가요?",
            "utterance_id": "BE22000034.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "코로나 후유증으로 몸이 많이 나빠졌는데 회복이 느려 업무 시간을 조정했었거든요.",
            "utterance_id": "BE22000034.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "고의로 그런 것도 아닌데 그런 거 하나 이해를 못 해주다니요.",
            "utterance_id": "BE22000034.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "코로나도 근무 중에 걸렸는데 말이죠.",
            "utterance_id": "BE22000034.7"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "제가 다 속상하네요. 구직이야 전문직이니 금방 구하겠지만, 마음 상한 거는 누가 보상 해 주겠어요.",
            "utterance_id": "BE22000034.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "자존심도 상하고, 당황스럽기도 하고 막상 당하니 기분이 바닥으로 꺼지는 거 같아요.",
            "utterance_id": "BE22000034.9"
        },
        {
            "listener_empathy": [
                "조언",
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당연히 그런 마음이 들지요. 그동안 제대로 쉬지도 못하고 일하셨으니 억울한 마음도 들겠어요. 당분간은 아무 생각 말고 푹 좀 쉬면서 몸을 좀 챙기세요.",
            "utterance_id": "BE22000034.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래야겠어요. 실은 많이 지쳐 있기도 했거든요.",
            "utterance_id": "BE22000034.11"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "제가 봐도 저러다 쓰러지는 거 아닌가 염려가 될 정도로 앞만 보고 달리셨어요.",
            "utterance_id": "BE22000034.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "이렇게라도 하소연하니 속이 좀 풀리네요.",
            "utterance_id": "BE22000034.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "쌓인 것은 주거니 받거니 이야기하다 보면 마음 안에서 정리가 되기도 하잖아요.",
            "utterance_id": "BE22000034.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그런 것 같네요.",
            "utterance_id": "BE22000034.15"
        }
    ]
}