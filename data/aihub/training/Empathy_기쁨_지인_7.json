    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이번에도 주말농장 분양을 받았어.",
            "utterance_id": "BE22000370.1"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아 진짜? 정말 잘 됐다. 언니 작년에도 텃밭 가꾸는 거 재밌어했잖아.",
            "utterance_id": "BE22000370.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 그래서 올해도 다시 열심히 해보려고.",
            "utterance_id": "BE22000370.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 지난해 언니가 준 상추 맛있게 먹었잖아.",
            "utterance_id": "BE22000370.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 가족들도 밭에서 막 딴 채소를 맛있게 먹는 거 보면 뿌듯하고 행복해.",
            "utterance_id": "BE22000370.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아. 확실히 파는 것하곤 틀려. 그래서 이번엔 뭐 심을 거야?",
            "utterance_id": "BE22000370.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우선 상추 먼저 심고 토마토랑 가지를 심을 예정이야.",
            "utterance_id": "BE22000370.7"
        },
        {
            "listener_empathy": [
                "격려",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "언니는 진짜 부지런하다. 난 아침잠이 많아서 절대 못할 것 같아.",
            "utterance_id": "BE22000370.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "새벽에 텃밭에 나가보면 나보다 부지런한 사람 많아. 은퇴하신 분들도 많이 계시고.",
            "utterance_id": "BE22000370.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래 작은 텃밭도 사람의 손이 무심해지면 금방 시들해지겠지.",
            "utterance_id": "BE22000370.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "작년에 한번 경험해 보니 올해는 더 잘할 수 있겠다는 자신감이 생겼어.",
            "utterance_id": "BE22000370.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "예쁘게 가꾼 언니 텃밭을 보면 존경스러워. 올해도 언니가 키운 건강한 채소로 언니 주변 사람들이 행복해할 거야.",
            "utterance_id": "BE22000370.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "조금만 기다려 건강한 채소 잔뜩 나눠줄게!",
            "utterance_id": "BE22000370.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "고마워 언니. 일손 필요하면 언제든지 불러.",
            "utterance_id": "BE22000370.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "나도 작은 행복이 하나 생겨서 벌써부터 기대된다.",
            "utterance_id": "BE22000370.15"
        }
    ]
}