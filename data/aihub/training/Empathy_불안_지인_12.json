    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "하루에 만 보를 걷기로 했는데 겨우 한 달을 채우고 요즘은 못하고 있어요.",
            "utterance_id": "BE22000751.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "대단해요, 감정화자씨. 만 보씩 걷기가 쉬운 일은 아니잖아요.",
            "utterance_id": "BE22000751.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "한번 마음먹은 목표를 일 년도 채우지 못하고 흐지부지되는 것 같아서 나 자신이 실망스러워요.",
            "utterance_id": "BE22000751.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "환절기여서 컨디션이 달라져서 아닐까?",
            "utterance_id": "BE22000751.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그런가요? 요즘 아침에 일어나기도 힘들긴 했어요.",
            "utterance_id": "BE22000751.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "무리하게 하다가 건강을 해칠까 봐 걱정스럽네요.",
            "utterance_id": "BE22000751.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "매일같이 안 해도 일주일에 서너 번쯤 해도 충분할까요?",
            "utterance_id": "BE22000751.7"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 나이는 그것으로 충분히 건강을 챙길 수 있으니 걱정하지 마요.",
            "utterance_id": "BE22000751.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "한때는 달리기도 했었어요.",
            "utterance_id": "BE22000751.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "달라기까지 했다고요? 대단한 열정이에요.",
            "utterance_id": "BE22000751.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "달릴 때 무릎 관절이 부서질 듯이 아파서 나이를 먹었구나 실감이 되었어요.",
            "utterance_id": "BE22000751.11"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오랫동안 써왔으니 그럴 만도 하지요.",
            "utterance_id": "BE22000751.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이젠 달리기를 할 수 없는 몸이 되었구나 싶은 것이 기분이 좀 그렇더라고요.",
            "utterance_id": "BE22000751.13"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": " 씩씩하게 걸을 수 있으니 얼마나 다행이에요.",
            "utterance_id": "BE22000751.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "감사해야 하겠지요. 그렇게 매일 걷기 목표를 세울 수 있는 마음이라도 있는걸요.",
            "utterance_id": "BE22000751.15"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그게 건강한 거예요. 그런 마음도 못 먹는 사람이 대부분이니까요.",
            "utterance_id": "BE22000751.16"
        }
    ]
}