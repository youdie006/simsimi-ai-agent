    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마, 날씨가 너무 좋지 않아요?",
            "utterance_id": "BE22001664.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어느새 비가 흔적도 없이 싹 사라진 것 같은데.",
            "utterance_id": "BE22001664.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "찬란한 햇빛, 살며시 살갗에 와닿는 바람 너무 좋아요.",
            "utterance_id": "BE22001664.3"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게. 비가 온 후라 햇빛과 바람이 더 선명하게 느껴지네. 엄마도 기분이 덩달아 좋아진다.",
            "utterance_id": "BE22001664.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄마 대학 입시 때 기억나요?",
            "utterance_id": "BE22001664.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "합격 발표 날 때까지 마음 졸이며 기다리던 거?",
            "utterance_id": "BE22001664.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "정말 이렇게 열심히 했는데, 안되면 어쩌지 싶어 걱정 많았었거든요.",
            "utterance_id": "BE22001664.7"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "걱정할 만하지. 나도 너 또 고생할까 봐 마음이 그랬었어.",
            "utterance_id": "BE22001664.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "합격 발표가 나고 나서야 숨이 쉬어지더라고요.",
            "utterance_id": "BE22001664.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그때 생각하면 눈물 나지.",
            "utterance_id": "BE22001664.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘 날씨가 그날 같아요.",
            "utterance_id": "BE22001664.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "비 온 끝에 축복처럼 내리는 햇살과 신선한 바람이?",
            "utterance_id": "BE22001664.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네, 합격과 동시에 안심이 되면서 하루하루가 신나더라고요.",
            "utterance_id": "BE22001664.13"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아, 너 한동안 집에서 얼굴 보기 힘들었을 정도로 신나게 다녔지.",
            "utterance_id": "BE22001664.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "이런 날씨에 이런 기분이 평화로움인 것 같아요.",
            "utterance_id": "BE22001664.15"
        }
    ]
}