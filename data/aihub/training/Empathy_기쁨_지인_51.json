    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘 강아지 간식을 사봤어요.",
            "utterance_id": "BE22001889.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "강아지 키워요? 얼마 전까지만 해도 그런 이야기 없었잖아요.",
            "utterance_id": "BE22001889.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "저희 집은 강아지 안 키워요. 사실은 옆집 강아지 간식을 산 거예요.",
            "utterance_id": "BE22001889.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "옆집 강아지 간식까지 챙기신 거 보니 강아지 좋아하시나봐요? 그럼 입양을 해보지 그러세요?",
            "utterance_id": "BE22001889.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어렸을 때부터 강아지를 키워보고 싶었는데 엄마가 알레르기가 있으셔서 못 키웠어요.",
            "utterance_id": "BE22001889.5"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "안타깝지만, 알레르기면 어떻게 해볼 도리가 없겠네요.",
            "utterance_id": "BE22001889.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러니까요. 그런데 옆집에 어르신 두 분이 사시는데 강아지가 저만 보면 쪼르르 따라오니까 가끔 산책도 부탁하시곤 해서 안 이뻐 할 수가 없어요.",
            "utterance_id": "BE22001889.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "강아지 키우는 게 소원이였는데 그렇게 따라오면 어떻게 안 이뻐해요. 강아지도 누가 자기 이뻐하는지 다 안다고 하더라고요. 이미 알고 있는 거예요.",
            "utterance_id": "BE22001889.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래서 자꾸 강아지 간식도 사들고 가게 되더라구요.",
            "utterance_id": "BE22001889.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "왜 아니겠어요. 저 같으면 간식 말고 옷도 장난감도 사주고 싶겠어요.",
            "utterance_id": "BE22001889.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래서 저도 모르게 자꾸 뭘 사더라구요. 이번 주말에는 여행 가신다고 저한테 강아지 부탁하셔서 전 벌써부터 기분이 좋아요.",
            "utterance_id": "BE22001889.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러다가 그 강아지 주인 어르신들보다 더 잘 따르겠어요.",
            "utterance_id": "BE22001889.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "진짜 그러면 어쩌죠? 순간 기대할 뻔했어요.",
            "utterance_id": "BE22001889.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "강아지도 같이 놀아주기 기대할 거 같아요. 이런 것도 부럽네요.",
            "utterance_id": "BE22001889.14"
        }
    ]
}