    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아버지가 저렇게 누워만 계시다가 그대로 돌아가실까 봐 너무 무서워.",
            "utterance_id": "BE22000349.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "마음 약한 소리 하지 마. 아버님 곧 일어나실 거야.",
            "utterance_id": "BE22000349.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어려우실 것 같아. 의사 선생님도 지켜보는 것 외에는 더 이상 방법이 없을 것 같다고 하셨거든.",
            "utterance_id": "BE22000349.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아무리 의사가 그렇게 얘기해도 환자의 의지에 따라 달라지기도 하잖아.",
            "utterance_id": "BE22000349.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래서 오늘부터 형제들과 돌아가면서 누워 계신 아버지에게 얘기를 해드리기로 했어. 눈은 못 뜨고 계셔도 들으실 수는 있지 않을까 해서.",
            "utterance_id": "BE22000349.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "정말 잘했네. 비록 의식은 없지만 가족들의 목소리에 반응해서 의식이 돌아올 수도 있어.",
            "utterance_id": "BE22000349.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘도 어릴 때 아버지랑 놀이동산 놀러 갔던 얘기를 해드리다가 감정이 북받쳐 내가 울고 말았어.",
            "utterance_id": "BE22000349.7"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당신 마음 모르는 거 아니라, 나도 가슴이 아프다. 당연히 눈물이 날 수밖에 없지.",
            "utterance_id": "BE22000349.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "한 가닥 희망을 걸어보는 거야.",
            "utterance_id": "BE22000349.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당신 너무 힘들 테니까, 나도 교대로 아버님 곁에 있을게.",
            "utterance_id": "BE22000349.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "당신은 회사도 가야 하는데 병실까지 지켜달라고 하면 내가 너무 미안하잖아.",
            "utterance_id": "BE22000349.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사위도 아들인데 그 정도는 해야지.",
            "utterance_id": "BE22000349.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "고마워. 우리 모두 이렇게 마음을 모으다 보면 좋은 일이 생길 수도 있겠지?",
            "utterance_id": "BE22000349.13"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "세상에는 기적이라는 것이 있으니까 끝까지 포기하지 말고 기운을 내.",
            "utterance_id": "BE22000349.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "응, 그러도록 할게. 고마워 여보.",
            "utterance_id": "BE22000349.15"
        }
    ]
}