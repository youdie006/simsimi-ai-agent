    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "여보 우리 큰애가 크루즈 여행 예약해 준 거 생각할수록 감동이야.",
            "utterance_id": "BE22001540.1"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러니까 나도 너무 뭉클해. 우리 애가 언제 저렇게 컸지?",
            "utterance_id": "BE22001540.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "직장을 다녀도 내 눈에는 여전히 아이 같았는데 이제 다 컸나봐.",
            "utterance_id": "BE22001540.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "하긴 우리가 결혼 20주년이니까 우리 애도 그만큼 큰 거겠지.",
            "utterance_id": "BE22001540.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "시간 참 빠르다. 우리가 함께한 시간이 벌써 20년이라니.",
            "utterance_id": "BE22001540.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 결혼식 했을 때, 큰 애 낳았을 때 아직도 다 눈에 선해.",
            "utterance_id": "BE22001540.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 그래. 그래도 우리가 아이를 잘 키웠나봐.",
            "utterance_id": "BE22001540.7"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게. 사랑으로 키운다고 노력했잖아.",
            "utterance_id": "BE22001540.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "큰 애가 그동안 잘 키워주셔서 감사하다고 인사할 때 정말 눈물 나더라.",
            "utterance_id": "BE22001540.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 그날 너무 기뻐서 잠이 안 왔어.",
            "utterance_id": "BE22001540.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그런 마음을 전해준 것만 해도 고마운데 크루즈 여행까지 보내주다니.",
            "utterance_id": "BE22001540.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "큰 애가 좀 무리한 건 아닐지 걱정도 된다.",
            "utterance_id": "BE22001540.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 그게 좀 걱정이야.",
            "utterance_id": "BE22001540.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "큰 애 몰래 우리가 적금을 하나 들어줄까?",
            "utterance_id": "BE22001540.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "좋은 생각이야! 일단 즐겁게 여행 다녀오고 나서 더 생각해보자.",
            "utterance_id": "BE22001540.15"
        }
    ]
}