    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사진 보낸 거 봤어?",
            "utterance_id": "BE22001666.1"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 우리 딸 그림 실력이 이렇게 대단했단 말이야?",
            "utterance_id": "BE22001666.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러니까. 나 이 그림 받자마자 눈물 흘린 거 알아?",
            "utterance_id": "BE22001666.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "엄청 감동받았구나. 어쩐지 아까 통화할 때 목소리가 좋던데 이것 때문이야?",
            "utterance_id": "BE22001666.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 언제 다 커서 이런 멋진 그림도 그려오고. 참 시간 빠르다.",
            "utterance_id": "BE22001666.5"
        },
        {
            "listener_empathy": [
                "격려",
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게. 다 당신 덕분이지. 당신이 유치원 가기 전까지 24시간 같이 있느라고 애 많이 썼지.",
            "utterance_id": "BE22001666.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나만 애썼나 뭐. 자기도 같이 보낸 시간인데.",
            "utterance_id": "BE22001666.7"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그렇게 말해주면 내가 더 면목이 없는데. 항상 바빴잖아.",
            "utterance_id": "BE22001666.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 가족 모두 아프지 않고, 큰일 없이 이렇게 사는 것만으로 하늘에 감사해.",
            "utterance_id": "BE22001666.9"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "우리 아내는 어쩜 이렇게 마음씨도 고울까?",
            "utterance_id": "BE22001666.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너무 비행기 태우지 마. 안 그래도 날아갈 것 같단 말이야.",
            "utterance_id": "BE22001666.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이렇게 좋아하는데, 유치원에 전화해서 매일매일 초상화 그리기 시간 갖자고 그래.",
            "utterance_id": "BE22001666.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "마음 같아선 진짜 그러고 싶더라니까. 다른 집 부모들도 이러겠지?",
            "utterance_id": "BE22001666.13"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내 생각에 당신이 특히 심한 것 같아. 눈물까지 흘렸다며.",
            "utterance_id": "BE22001666.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "다음에는 자기 얼굴 그리라고 해야겠다. 그럼 자기도 눈물날 거야.",
            "utterance_id": "BE22001666.15"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "와. 생각만 해도 코끝이 찡한데?",
            "utterance_id": "BE22001666.16"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "내 마음이 그 마음이라니까.",
            "utterance_id": "BE22001666.17"
        }
    ]
}