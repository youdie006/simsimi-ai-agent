    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아까 편의점 손님이 나한테 군인이냐고 물었어.",
            "utterance_id": "BE22001146.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그건 좀 뜬금없는 소리인데? 여군처럼 보였나?",
            "utterance_id": "BE22001146.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "계산하고 있는데 다짜고짜 그런 질문을 받으니까 어버버하게 되더라.",
            "utterance_id": "BE22001146.3"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나라도 갑자기 그런 말을 들으면 민망하고 당황할 것 같아.",
            "utterance_id": "BE22001146.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 편의점 조끼 안에 검은색 반팔 티셔츠를 입고 있었거든.",
            "utterance_id": "BE22001146.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그거하고 군인하고 무슨 상관인데?",
            "utterance_id": "BE22001146.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "가운데 501이라고 숫자 있잖아. 그 손님이 501부대를 나왔는데 동기들 기념 티셔츠가 그렇게 생겼대.",
            "utterance_id": "BE22001146.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아, 그래서 너도 거기 출신인 줄 알았구나. 너무 귀엽고 재미있는 착각이잖아.",
            "utterance_id": "BE22001146.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "나중에 생각하니까 웃겨서 한참 깔깔거렸잖아.",
            "utterance_id": "BE22001146.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "와, 나도 지금 상상하다가 웃음이 빵 터졌네.",
            "utterance_id": "BE22001146.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그 손님 덕분에 아르바이트 시간이 후딱 지나갔어.",
            "utterance_id": "BE22001146.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "지루한 오후에 활기가 돌았겠네. 일하면서 그런 맛도 있어야지.",
            "utterance_id": "BE22001146.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "가끔 엉뚱하고 재미있는 손님들 있는데 그중에서도 최고였어.",
            "utterance_id": "BE22001146.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그 손님 다음에 또 오면 좋겠다. 음료수라도 하나 드려.",
            "utterance_id": "BE22001146.14"
        }
    ]
}