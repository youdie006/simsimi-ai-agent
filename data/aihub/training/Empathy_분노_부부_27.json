    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "여보, 나 요즘 밥만 차리다 하루가 끝나는 거 같아.",
            "utterance_id": "BE22001324.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "미안, 당신 혼자 식사 준비하기 힘들었지?",
            "utterance_id": "BE22001324.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "매일 내가 식사를 챙겨야 한다는 게 너무 스트레스야.",
            "utterance_id": "BE22001324.3"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 요즘 바빠서 못 도와줬으니 당신 마음이 얼마나 힘들었을지 이해돼.",
            "utterance_id": "BE22001324.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "평일에도 주말에도 식사 준비하는 것 때문에 약속을 잡을 수가 없어.",
            "utterance_id": "BE22001324.5"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 곧 바쁜 일 끝나면 요일별로 번갈아서 준비하도록 하자.",
            "utterance_id": "BE22001324.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "정말? 그렇게 해줄 수 있어.",
            "utterance_id": "BE22001324.7"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응, 내가 그동안 고생한 당신 위해서 최대한 노력해 볼 테니깐 마음 풀어.",
            "utterance_id": "BE22001324.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "당신이 내 마음 이해해 주니 기분이 좀 나아졌어.",
            "utterance_id": "BE22001324.9"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "앞으로 주말에는 집밥 대신에 외식도 하고, 한 끼 정도는 내가 준비할게.",
            "utterance_id": "BE22001324.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그럼 나 앞으로 주말에 약속 잡아도 돼?",
            "utterance_id": "BE22001324.11"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "말 나온 김에 당신 스트레스도 풀 겸 이번 주말에 친구들 만나.",
            "utterance_id": "BE22001324.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "진짜? 그럼 애들 밥은 어떻게 해?",
            "utterance_id": "BE22001324.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아침부터 저녁까지 내가 다 챙겨 먹일 테니까 걱정 말고 재미있게 놀다 와.",
            "utterance_id": "BE22001324.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그럼 이번 주말엔 당신만 믿고 나갔다 올게.",
            "utterance_id": "BE22001324.15"
        }
    ]
}