    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "자기야 정말 수강신청 같이 해줄 거야?",
            "utterance_id": "BE22000355.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래 내가 도와줄게. pc방에서 만나자.",
            "utterance_id": "BE22000355.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "진짜 고마워 내가 자기 집 앞 pc방으로 갈게!",
            "utterance_id": "BE22000355.3"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래 주면 고맙지. 자기 저번에 수강신청 못해서 이번 학기 내내 고생했잖아. 그게 마음에 걸렸어.",
            "utterance_id": "BE22000355.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "배우고 싶었던 과목이 있었는데, 제때 못해서 정말 아쉬웠어.",
            "utterance_id": "BE22000355.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "수강신청 때문에 정작 배우고 싶은 걸 못 배운 심정이라니... 이번에는 그런 일 없도록 내가 도울게.",
            "utterance_id": "BE22000355.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너무 든든하다. 내가 끝나고 맛있는 거 사줄게!",
            "utterance_id": "BE22000355.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "요새 pc방에서 파는 음식 메뉴가 엄청나게 다양해. 자기 먹어볼래?",
            "utterance_id": "BE22000355.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그래? 나 pc방 가본 지 너무 오래돼서 재밌을 것 같아.",
            "utterance_id": "BE22000355.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "자기가 즐거워하니 내 기분이 다 좋아.",
            "utterance_id": "BE22000355.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그게 하고 싶어서 도와준다고 한 것 같은데?",
            "utterance_id": "BE22000355.11"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "아니야. 이왕 pc방에 왔으니까 같이 게임도 해보자는 거지.",
            "utterance_id": "BE22000355.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어이구 알겠어. 그래도 내 수강신청까지 챙겨주고 고마워.",
            "utterance_id": "BE22000355.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "자기 일이라면 내가 당연히 신경 쓰지. 얼른 수업 끝내고 만나자.",
            "utterance_id": "BE22000355.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "응. 끝나면 바로 갈게!",
            "utterance_id": "BE22000355.15"
        }
    ]
}