    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "요즘 대출 문자 왜 이렇게 많이 와요?",
            "utterance_id": "BE22000381.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러게요. 요즘 부쩍 많이 오더라고요.",
            "utterance_id": "BE22000381.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이거 은근히 사람 귀찮게 해요. 매일 차단하는 것도 너무 귀찮아요.",
            "utterance_id": "BE22000381.3"
        },
        {
            "listener_empathy": [
                "위로",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "특히 바쁠 때 오면 화까지 나더라고요. 나도 매번 차단했었는데 요즘에는 그것도 귀찮아서 그냥 내버려두게 되더라요.",
            "utterance_id": "BE22000381.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이거 신고할 수 있는 방법이 없을까요?",
            "utterance_id": "BE22000381.5"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "신고할 수 있으면 좋은데 문자 보내는 걸로 신고하기는 어려울 것 같아요.",
            "utterance_id": "BE22000381.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그럼 스팸 문자 신고라도 해야겠어요.",
            "utterance_id": "BE22000381.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "좋은 방법이네요. 나도 앞으로 오는 번호는 다 신고해야겠어요.",
            "utterance_id": "BE22000381.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어느 땐 전화도 오더라고요. 업무 전화인 줄 알고 받았는데 대출 전화면 얼마나 화가 나는지.",
            "utterance_id": "BE22000381.9"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "맞아요. 최근에는 휴대폰 번호로 오기도 하더라고요. 방법도 새로워지는 것 같아요.",
            "utterance_id": "BE22000381.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "처음에는 바쁜 일 있다고 하면서 끊었는데, 이제는 그냥 끊어요.",
            "utterance_id": "BE22000381.11"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도 대출 전화인 거 알면 그냥 바로 끊어요.",
            "utterance_id": "BE22000381.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그럴 때마다 내가 예의 없는 사람이 된 것 같아서 기분이 이상해요.",
            "utterance_id": "BE22000381.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어떻게 매번 대꾸를 해주겠어요. 우리도 일하느라 바쁜데요. 다들 비슷할 거예요.",
            "utterance_id": "BE22000381.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "그렇겠지요? 앞으로는 마음을 조금 편하게 먹어야겠어요.",
            "utterance_id": "BE22000381.15"
        }
    ]
}