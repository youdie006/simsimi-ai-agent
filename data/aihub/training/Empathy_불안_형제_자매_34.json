    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "언니, 오늘이 아르바이트 비용 받는 날인데, 어떻게 이런 일이 있지?",
            "utterance_id": "BE22001228.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "왜? 무슨 일인데 그래?",
            "utterance_id": "BE22001228.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "어제까지 아무 말도 없었는데, 출근해보니 카페가 폐업이라고 쓰여 있어.",
            "utterance_id": "BE22001228.3"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "네가 많이 당황스럽겠다. 사장님께는 연락은 했고? 다른 직원들은?",
            "utterance_id": "BE22001228.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나도, 직원들도 계속 연락해 봤는데 안 돼.",
            "utterance_id": "BE22001228.5"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "일단 며칠 기다려보고 연락 없으면 고용 노동부에 신고해 놔.",
            "utterance_id": "BE22001228.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "생활비도 다 써가는데 당분간 어떻게 해야 할지 모르겠어.",
            "utterance_id": "BE22001228.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "내가 이 주일 정도 버틸 돈은 먼저 보내줄게.",
            "utterance_id": "BE22001228.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "언니도 빠듯할 텐데 차라리 엄마한테 부탁할까?",
            "utterance_id": "BE22001228.9"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너 공부하면서 열심히 일까지 했는데 이런 상황 아시면 상심하실 수 있으니까 좀 기다려 보자.",
            "utterance_id": "BE22001228.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사장님 사람이 참 좋아 보였는데 어떻게 이럴 수가 있지?",
            "utterance_id": "BE22001228.11"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "사정이 갑자기 나빠지면 좋은 사람도 어쩔 수 없는 일에 놓이게도 되는 거니까 크게 실망하지는 말고.",
            "utterance_id": "BE22001228.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "돈 한 푼 못 받으면 그동안 일한 게 너무 억울하고 속 터질 것 같아.",
            "utterance_id": "BE22001228.13"
        },
        {
            "listener_empathy": [
                "조언",
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "깊게 마음 쓰지 마. 돈은 못 받을 수 있지만 일한 경험도, 지금 겪는 일들도 네가 살아가는 데 도움이 될 테니까.",
            "utterance_id": "BE22001228.14"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": true,
            "text": "언니가 있어서 의지가 되네. 언니 말대로 해보고 다시 연락할게.",
            "utterance_id": "BE22001228.15"
        }
    ]
}