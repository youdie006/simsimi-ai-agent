    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘자로 내 가게를 접었어. 이제 나는 실업자야.",
            "utterance_id": "BE22000627.1"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "왜 가게를 정리하셨어요, 사장님?",
            "utterance_id": "BE22000627.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이제 나를 사장이라고 부르지 마. 더 이상 사장 아니야.",
            "utterance_id": "BE22000627.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "벌써 6년째 해오던 가게였잖아요.",
            "utterance_id": "BE22000627.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "코로나인지 뭔지 그 악몽에서 결국 헤어나올 수가 없었어.",
            "utterance_id": "BE22000627.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "조금만 더 버텨보실 수는 없었나요? 조만간 코로나 상황이 좀 진정될 거 같아서 안타까워요.",
            "utterance_id": "BE22000627.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "벌써 2년 넘게 버티기만 했는데 그것도 버틸 힘이 있어야 가능한 거지.",
            "utterance_id": "BE22000627.7"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "2년 동안 적자가 많이 쌓여서 저도 걱정스럽긴 했어요.",
            "utterance_id": "BE22000627.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "정말 죽어라 고생만 했는데 이젠 그마저도 다 잃고 나니 아무 생각이 없다.",
            "utterance_id": "BE22000627.9"
        },
        {
            "listener_empathy": [
                "조언",
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "너무 낙담하지 마세요. 그러다 건강을 해치실까 걱정입니다.",
            "utterance_id": "BE22000627.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "이 상황에 내 몸 걱정이 다 무슨 소용이야.",
            "utterance_id": "BE22000627.11"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "가게는 다시 시작하면 되잖아요. 건강을 잃는 것은 모든 것을 잃는 것이라고 했어요.",
            "utterance_id": "BE22000627.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": "중립",
            "terminate": false,
            "text": "하긴 아픈 데라도 없어야 막노동이라도 다니겠지. 걱정해 줘서 고맙다.",
            "utterance_id": "BE22000627.13"
        },
        {
            "listener_empathy": [
                "조언"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "기운 내시고 뭘 좀 드시면 좋겠어요.",
            "utterance_id": "BE22000627.14"
        }
    ]
}