    "utterances": [
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "나 오늘 이만 보 걸었어.",
            "utterance_id": "BE22001587.1"
        },
        {
            "listener_empathy": [
                "위로"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "웬일이야. 주말에는 침대랑 떨어져 있기 힘들어하던 애가.",
            "utterance_id": "BE22001587.2"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "주말에 집에만 있는 게 한심한 것처럼 느껴져서 등산 모임에 가입했거든.",
            "utterance_id": "BE22001587.3"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오늘 그럼 거기 간 거야?",
            "utterance_id": "BE22001587.4"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응. 역에서 7시에 모여서 등산했어.",
            "utterance_id": "BE22001587.5"
        },
        {
            "listener_empathy": [
                "동조"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "말만 들어도 힘든데? 괜찮아? 산 처음 타보잖아.",
            "utterance_id": "BE22001587.6"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "처음엔 힘들었지. 근데 처음 타본다고 하니까 그 전날 복장부터 준비물까지 다 말해주고, 산 타면서도 계속 도와주시더라?",
            "utterance_id": "BE22001587.7"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "오 다행이다. 진짜 잘 챙겨주시네. 그럼 정상까지 간 거야?",
            "utterance_id": "BE22001587.8"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응, 그분들 아니었으면 끝까지 못 올라갔을 거야.",
            "utterance_id": "BE22001587.9"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "등산 모임 나간 보람이 있구먼. 진짜 뿌듯했겠는데?",
            "utterance_id": "BE22001587.10"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "응, 들어오길 잘했어. 다음 주 모임도 나가기로 했어.",
            "utterance_id": "BE22001587.11"
        },
        {
            "listener_empathy": [
                "격려"
            ],
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "잘했어. 뭐든 새롭게 경험해 봐야 좋은 것 같아.",
            "utterance_id": "BE22001587.12"
        },
        {
            "listener_empathy": null,
            "role": "speaker",
            "speaker_changeEmotion": null,
            "terminate": false,
            "text": "그러니까 말이야. 처음 해보는 일이라 겁먹었는데 그럴 필요 없었지 뭐야.",
            "utterance_id": "BE22001587.13"
        },
        {
            "listener_empathy": null,
            "role": "listener",
            "speaker_changeEmotion": null,
            "terminate": true,
            "text": "그 말 들으니 나도 도전하고 싶어지는걸.",
            "utterance_id": "BE22001587.14"
        }
    ]
}